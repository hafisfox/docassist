# Copy to .env.local and fill in real values. .env* is gitignored.

# ── Supabase ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── Unipile (LinkedIn automation) ─────────────────────────────────────────────
UNIPILE_API_KEY=
# Host:port of your Unipile DSN, e.g. api13.unipile.com:14349
UNIPILE_DSN=
UNIPILE_ACCOUNT_ID=

# ── Apify (profile scraping) ──────────────────────────────────────────────────
APIFY_API_TOKEN=

# ── OpenAI (message personalization) ──────────────────────────────────────────
OPENAI_API_KEY=

# ── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Shared secret echoed by Unipile in the Unipile-Auth webhook header
WEBHOOK_SECRET=

# ── n8n (workflow automation control plane) ───────────────────────────────────
# Base URL of the n8n instance (no trailing slash)
N8N_BASE_URL=https://n8n.srv1183265.hstgr.cloud
# n8n public API key — create at n8n → Settings → API. Sent as X-N8N-API-KEY.
# NOTE: this is NOT the MCP JWT in .mcp.json; that only works for the MCP endpoint.
N8N_API_KEY=
# Shared secret the n8n HTTP Request nodes echo in the `x-n8n-auth` header when
# POSTing events to /api/webhooks/n8n
N8N_WEBHOOK_SECRET=
# Which engine owns outreach execution: "n8n" (recommended) disables the
# dashboard's local sequence executor + Unipile webhook so the two engines can't
# double-send. Set to "dashboard" to keep the local executor authoritative.
AUTOMATION_ENGINE=n8n
# Supabase user id that n8n-synced leads (which have no session) are attached to.
# Single-operator system. If unset, the ingest webhook falls back to the sole
# row in `profiles`.
DASHBOARD_OWNER_USER_ID=

# ── Logging ───────────────────────────────────────────────────────────────────
# One of: trace | debug | info | warn | error | fatal
LOG_LEVEL=info
