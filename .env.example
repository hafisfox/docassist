# Copy to .env.local and fill in real values. .env* is gitignored.

# ── Supabase ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── Unipile (LinkedIn automation) ─────────────────────────────────────────────
UNIPILE_API_KEY=
# Host:port of your Unipile DSN, e.g. api13.unipile.com:14349
UNIPILE_DSN=
UNIPILE_ACCOUNT_ID=

# ── Apify (profile scraping) ──────────────────────────────────────────────────
APIFY_API_TOKEN=

# ── OpenAI (message personalization) ──────────────────────────────────────────
OPENAI_API_KEY=

# ── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Shared secret echoed by Unipile in the Unipile-Auth webhook header
WEBHOOK_SECRET=

# ── Logging ───────────────────────────────────────────────────────────────────
# One of: trace | debug | info | warn | error | fatal
LOG_LEVEL=info
