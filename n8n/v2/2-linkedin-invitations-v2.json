    {
      "parameters": {
        "jsCode": "// Access all incoming items from the previous node\nconst items = $input.all();\nconst results = [];\n\nconst prefix = 'ERR-';\nconst characters = 'ABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789';\n\n// Loop through each incoming item\nfor (const item of items) {\n  // 1. Generate the 6-character random string for this item\n  let randomString = '';\n  for (let i = 0; i < 6; i++) {\n    const randomIndex = Math.floor(Math.random() * characters.length);\n    randomString += characters[randomIndex];\n  }\n  const finalErrorId = prefix + randomString;\n\n  // 2. Capture all the existing data from the previous node\n  // If item.json exists, we grab it. Otherwise, we default to an empty object.\n  const previousData = item.json || {};\n\n  // 3. Combine the new error ID with the previous details and add it to results\n  results.push({\n    json: {\n      errorId: finalErrorId,\n      ...previousData // The spread operator (...) copies all existing fields over\n    }\n  });\n}\n\n// Return the properly formatted array of objects for n8n\nreturn results;"
      },
