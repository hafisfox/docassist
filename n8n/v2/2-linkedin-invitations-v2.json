      "parameters": {
        "jsCode": "const invites = $('readInvites').all().map(i => i.json);\nconst now = new Date();\n// IST \"today\" string matching sheet format dd/MM/yy\nconst ist = new Date(now.getTime() + 5.5*3600*1000);\nconst pad = n => String(n).padStart(2,'0');\nconst todayStr = pad(ist.getUTCDate()) + '/' + pad(ist.getUTCMonth()+1) + '/' + String(ist.getUTCFullYear()).slice(-2);\nfunction within14(s){ if(!s) return false; const p=String(s).split(' ')[0].split('/'); if(p.length<3) return false; const d=new Date(2000+ +p[2], +p[1]-1, +p[0]); return (now-d)/(86400000) <= 14; }\nlet sent14=0, acc14=0, pending=0, sentToday=0;\nfor (const r of invites) {\n  const st = String(r.invite_status||'').toLowerCase();\n  if (within14(r.sent_at)) { sent14++; if (st==='accepted') acc14++; }\n  if (st==='sent') pending++;\n  if (String(r.sent_at||'').startsWith(todayStr)) sentToday++;\n}\nconst acceptance = sent14 > 0 ? acc14/sent14 : 1;       // no signal yet -> allow\nconst istHour = ((now.getUTCHours() + now.getUTCMinutes()/60 + 5.5) % 24 + 24) % 24;\nconst inHours = istHour >= 7 && istHour < 22;\nconst killed = sent14 >= 20 && acceptance < 0.25;        // only trip with enough signal\nconst pendingBlock = pending >= 150;\nconst dailyDone = sentToday >= 20;\nif (!inHours || killed || pendingBlock || dailyDone) return []; // HALT this run\nreturn [{ json: { proceed:true, acceptancePct: Math.round(acceptance*100), pending, sentToday, remainingToday: Math.max(0, 20 - sentToday) } }];"
      },
