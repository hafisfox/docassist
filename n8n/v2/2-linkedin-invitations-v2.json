    {
      "parameters": {
        "jsCode": "const offsets = { IN:5.5, AE:4, SA:3, QA:3, KW:3, OM:4, SG:8, UK:0, IE:0, NL:1, BE:1, SE:1, DK:1, NO:1, FI:2, AT:1, CH:1, DE:1, FR:1, US_ET:-5 };\nconst EU = ['UK','IE','NL','BE','SE','DK','NO','FI','AT','CH','DE','FR'];\nconst now = new Date();\nconst utc = now.getUTCHours() + now.getUTCMinutes()/60;\nconst m = now.getUTCMonth(); // 0=Jan\nconst isSummer = m >= 2 && m <= 9; // ~DST window (approx)\nconst out = [];\nfor (const it of $input.all()) {\n  let r = (it.json.region || 'IN').trim() || 'IN';\n  let off = offsets[r]; if (off === undefined) off = 5.5; // unknown -> founder IST morning\n  if (isSummer && (EU.includes(r) || r === 'US_ET')) off += 1;\n  const localAbs = utc + off;\n  const localHour = ((localAbs % 24) + 24) % 24;\n  let dow = now.getUTCDay(); // 0=Sun..6=Sat\n  if (localAbs >= 24) dow = (dow + 1) % 7; else if (localAbs < 0) dow = (dow + 6) % 7;\n  const weekday = dow >= 1 && dow <= 5;\n  if (weekday && localHour >= 9 && localHour < 11.5) out.push(it);\n}\nreturn out;"
      },
