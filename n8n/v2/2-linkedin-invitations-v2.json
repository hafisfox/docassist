    {
      "parameters": {
        "jsCode": "const lead = $('loop').item.json;\nconst seg = String(lead.segment||'').toUpperCase();\nconst first = (String(lead.full_name||'').trim().split(/\\s+/)[0]) || 'there';\nconst hospital = String(lead.hospital_name||'').trim();\nconst templateSafe = String(lead.template_safe||'').toUpperCase() === 'TRUE' && !!hospital;\nconst topic = String(lead.topic||'').trim();\nconst lastPost = lead.last_post_date || '';\nfunction recentPoster(){ if(!lastPost) return false; const d=new Date(lastPost); if(isNaN(d)) return false; return (Date.now()-d)/(86400000) <= 60; }\nfunction clip(s){ s=(s||'').trim(); return s.length>300 ? s.slice(0,297).trim()+'...' : s; }\nlet note = '';\nif (seg === 'DOCTOR') {\n  if (recentPoster() && topic) note = `Hi Dr. ${first}, came across your posts on ${topic} — clear you actively explore new technology in practice, which I value as well. Thought it would be great to connect.`;\n} else { // CMO / CIO / ADMIN\n  if (templateSafe) {\n    note = (seg === 'CIO')\n      ? `Hi ${first} — came across ${hospital} while mapping hospitals investing in clinical AI. We build a clinical-AI layer that integrates over HL7 FHIR — no rip-and-replace. Thought it would be valuable to connect.`\n      : `Hi ${first} — came across ${hospital} while mapping hospitals investing in clinical AI. We build decision-support that runs alongside the existing EHR rather than replacing it. Thought it would be valuable to connect.`;\n  }\n}\nreturn [{ json: { ...lead, note_text: clip(note) } }];"
      },
